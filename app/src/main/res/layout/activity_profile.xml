<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Volver" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mi perfil"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center" />

            <View android:layout_width="24dp" android:layout_height="24dp" />
        </LinearLayout>

        <!-- Avatar + nombre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="28dp"
            android:paddingBottom="16dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:background="#FFFFFF">

            <!-- Avatar circular -->
            <androidx.cardview.widget.CardView
                android:layout_width="112dp"
                android:layout_height="112dp"
                app:cardCornerRadius="56dp"
                app:cardElevation="6dp">

                <ImageView
                    android:id="@+id/imgPerfilGrande"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_profile"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- Botón cambiar foto debajo del avatar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/imgCambiarFoto"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="12dp"
                android:text="Cambiar foto"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1A1A2E"
                app:cornerRadius="18dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp" />

            <!-- Nombre + ícono editar -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/txtNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuario"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <ImageView
                    android:id="@+id/imgEditarPerfil"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_edit"
                    android:layout_marginLeft="8dp"
                    android:contentDescription="Editar nombre y correo"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Formulario de edición (fondo oscuro para que los textos sean visibles) -->
        <LinearLayout
            android:id="@+id/layoutEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#1A1A2E"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textSize="13sp"
                android:textColor="#BBBBBB"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtNombrePerfil"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Nombre completo"
                android:inputType="textPersonName"
                android:background="#2C2C4A"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo"
                android:textSize="13sp"
                android:textColor="#BBBBBB"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtCorreoPerfil"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="correo@ejemplo.com"
                android:inputType="textEmailAddress"
                android:background="#2C2C4A"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:layout_marginBottom="18dp" />

            <Button
                android:id="@+id/btnGuardarPerfil"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Guardar cambios"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Menú de opciones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#F5F5F5"
                android:padding="16dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Datos personales" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="#757575" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#F5F5F5"
                android:padding="16dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Seguridad" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="#757575" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#F5F5F5"
                android:padding="16dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Notificaciones" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="#757575" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#F5F5F5"
                android:padding="16dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Ayuda" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="22sp" android:textColor="#757575" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
