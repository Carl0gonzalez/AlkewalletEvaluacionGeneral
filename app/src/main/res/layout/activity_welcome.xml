<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Zona celeste superior con borde inferior redondeado -->
    <LinearLayout
        android:id="@+id/headerCeleste"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_header_celeste"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgLogoWelcome"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_splash_logo" />

        <TextView
            android:id="@+id/txtAppNameWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alke Wallet"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Zona blanca inferior -->
    <LinearLayout
        android:id="@+id/contentBlanco"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <Button
            android:id="@+id/btnCrearCuenta"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Crear nueva cuenta"
            android:backgroundTint="@color/colorCeleste"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

        <TextView
            android:id="@+id/btnYaTieneCuenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ya tiene cuenta"
            android:textColor="@color/colorCeleste"
            android:textSize="15sp"
            android:layout_marginTop="20dp" />
    </LinearLayout>

</LinearLayout>
