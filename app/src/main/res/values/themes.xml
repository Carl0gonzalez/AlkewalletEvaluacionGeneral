<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AlkeWallet" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorCeleste</item>
        <item name="colorPrimaryVariant">@color/colorCelesteSuave</item>
        <item name="colorOnPrimary">@color/colorBlanco</item>
        <item name="colorSecondary">@color/colorVerde</item>
        <item name="android:statusBarColor">@color/colorCeleste</item>
        <item name="textInputStyle">@style/Widget.AlkeWallet.TextInputLayout</item>

    </style>
    <style name="Widget.AlkeWallet.TextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

</resources>
